#!/usr/bin/env bash
# =============================================================================
# docker-push — Centralized Docker push with versioning for Docker services
#
# Resolves patch version via Infisical, retags, and pushes.
#
# Usage:
#   docker-push                         # auto-detect from CWD or last build
#   docker-push my-frontend             # explicit target
#   docker-push my-backend --dry-run    # preview without pushing
#   docker-push my-frontend -up         # force patch increment (non-prod)
#   docker-push my-backend --verbose    # stream docker push output live
#   docker-push --all                   # push all repos (zellij panes)
#   docker-push --pick                  # interactive selection, push in panes
#   docker-push --include my-backend,my-frontend  # specific targets
#   docker-push --all --no-zellij       # push all repos sequentially
#   BUILD_ENV=prod docker-push          # override environment
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INFRA_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$SCRIPT_DIR/../k8-lib/docker-config.sh"

# --- Toggle-list helper ------------------------------------------------------
# Usage: _toggle_input SELECTED_ARRAY_NAME MAX_COUNT
#   Reads one line of input, applies toggle commands to the named array.
#   Returns 0 to continue loop, 1 to break (go/enter), 2 to quit.
#   Supports: single number, space/comma-separated numbers, ranges (1-5),
#             'a' = all, 'n' = none, 'go'/enter = confirm, 'q' = quit
# Note: uses eval for bash 3.2 compat (no nameref). Array name is always
#       a hardcoded literal from our own code, never user input.
_toggle_input() {
  local arr_name="$1"
  local max="$2"
  local input

  read -r -p "> " input
  [[ "$input" == "q" ]] && return 2
  [[ -z "$input" || "$input" == "go" ]] && return 1

  if [[ "$input" == "a" ]]; then
    for (( i=0; i<max; i++ )); do eval "${arr_name}[$i]=true"; done
    return 0
  elif [[ "$input" == "n" ]]; then
    for (( i=0; i<max; i++ )); do eval "${arr_name}[$i]=false"; done
    return 0
  fi

  # Parse space/comma-separated tokens, each can be a number or range (e.g. 3-7)
  local token
  for token in $(echo "$input" | tr ',' ' '); do
    if [[ "$token" =~ ^([0-9]+)-([0-9]+)$ ]]; then
      local lo="${BASH_REMATCH[1]}" hi="${BASH_REMATCH[2]}"
      local n
      for (( n=lo; n<=hi; n++ )); do
        if (( n >= 1 && n <= max )); then
          local ti=$((n - 1))
          local cur
          eval "cur=\${${arr_name}[$ti]}"
          if [[ "$cur" == "true" ]]; then eval "${arr_name}[$ti]=false"; else eval "${arr_name}[$ti]=true"; fi
        fi
      done
    elif [[ "$token" =~ ^[0-9]+$ ]] && (( token >= 1 && token <= max )); then
      local ti=$((token - 1))
      local cur
      eval "cur=\${${arr_name}[$ti]}"
      if [[ "$cur" == "true" ]]; then eval "${arr_name}[$ti]=false"; else eval "${arr_name}[$ti]=true"; fi
    fi
  done
  return 0
}

# --- Parse flags -------------------------------------------------------------
DRY_RUN=false
FORCE_UP=false
VERBOSE=false
PUSH_ALL=false
PUSH_PICK=false
NO_ZELLIJ=false
INCLUDE_LIST=""
TARGET=""
VSN_POSITIONAL=""

RELEASE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true ;;
    -up)       FORCE_UP=true ;;
    --verbose) VERBOSE=true ;;
    --yes|-y)  AUTO_YES=true ;;
    --all)     PUSH_ALL=true ;;
    --pick)    PUSH_PICK=true ;;
    --no-zellij) NO_ZELLIJ=true ;;
    --release) RELEASE=true ;;
    --include=*) INCLUDE_LIST="${1#--include=}" ;;
    --include)   INCLUDE_LIST="$2"; shift ;;
    -*)        ;; # ignore other flags
    *)
      if [[ -z "$TARGET" ]]; then
        if is_docker_repo "$1"; then
          TARGET="$1"
        else
          VSN_POSITIONAL="$1"
        fi
      else
        VSN_POSITIONAL="$1"
      fi
      ;;
  esac
  shift
done

# --- Validate flag combinations -----------------------------------------------
PUSH_INCLUDE=false
if [[ -n "$INCLUDE_LIST" ]]; then
  PUSH_INCLUDE=true
fi

_multi_count=0
$PUSH_ALL && ((_multi_count++)) || true
$PUSH_PICK && ((_multi_count++)) || true
$PUSH_INCLUDE && ((_multi_count++)) || true
if (( _multi_count > 1 )); then
  echo "❌  --all, --pick, and --include are mutually exclusive"
  exit 1
fi

if [[ -n "$TARGET" ]] && ($PUSH_ALL || $PUSH_PICK || $PUSH_INCLUDE); then
  echo "❌  Cannot specify a target with --all, --pick, or --include"
  exit 1
fi

# =============================================================================
# MULTI-PUSH MODE (--all, --pick, or --include)
# =============================================================================
if $PUSH_ALL || $PUSH_PICK || $PUSH_INCLUDE; then
  TARGETS=()

  if $PUSH_INCLUDE; then
    IFS=',' read -ra _inc_items <<< "$INCLUDE_LIST"
    for item in "${_inc_items[@]}"; do
      item="${item## }"; item="${item%% }"
      if is_docker_repo "$item"; then
        TARGETS+=("$item")
      else
        echo "⚠️  Unknown target in --include: $item"
        echo "   Known repos: ${DOCKER_REPOS[*]}"
        exit 1
      fi
    done
    echo "Pushing: ${TARGETS[*]}"
  elif $PUSH_ALL; then
    TARGETS=("${DOCKER_REPOS[@]}")
    echo "Pushing all repos: ${TARGETS[*]}"
  else
    # --- Interactive pick (toggle list) ---
    SELECTED=()
    for _repo in "${DOCKER_REPOS[@]}"; do
      SELECTED+=(false)
    done

    echo "Select repos to push:"
    for i in "${!DOCKER_REPOS[@]}"; do
      echo "  [ ] $((i+1))) ${DOCKER_REPOS[$i]}"
    done
    echo ""
    echo "Toggle by number, 'a' = all, 'n' = none, Enter = go, 'q' = quit"

    while true; do
      _toggle_input SELECTED "${#DOCKER_REPOS[@]}" && rc=0 || rc=$?
      [[ $rc -eq 2 ]] && { echo "Aborted."; exit 0; }
      [[ $rc -eq 1 ]] && break

      for i in "${!DOCKER_REPOS[@]}"; do
        mark="[ ]"
        [[ "${SELECTED[$i]}" == "true" ]] && mark="[x]"
        echo "  ${mark} $((i+1))) ${DOCKER_REPOS[$i]}"
      done
    done

    for i in "${!DOCKER_REPOS[@]}"; do
      if [[ "${SELECTED[$i]}" == "true" ]]; then
        TARGETS+=("${DOCKER_REPOS[$i]}")
      fi
    done

    if (( ${#TARGETS[@]} == 0 )); then
      echo "No repos selected."
      exit 0
    fi

    echo ""
    echo "Pushing: ${TARGETS[*]}"
  fi

  # --- Build passthrough flags ------------------------------------------------
  PANE_FLAGS=""
  $DRY_RUN && PANE_FLAGS+=" --dry-run"
  $FORCE_UP && PANE_FLAGS+=" -up"
  $VERBOSE && PANE_FLAGS+=" --verbose"
  $RELEASE && PANE_FLAGS+=" --release"
  [[ "${AUTO_YES:-}" == "true" ]] && PANE_FLAGS+=" --yes"

  # --- Zellij multi-push mode -------------------------------------------------
  if command -v zellij &>/dev/null && ! $NO_ZELLIJ; then
    SESSION_NAME="push-$(date +%H%M%S)"
    layout_file="$(mktemp /tmp/docker-push-zj-XXXXXX.kdl)"

    {
      echo "layout {"
      echo "  tab name=\"pushes\" {"
      for image in "${TARGETS[@]}"; do
        echo "    pane name=\"${image}\" {"
        echo "      command \"bash\""
        echo "      args \"-c\" \"docker-push ${image}${PANE_FLAGS}; exec bash\""
        echo "    }"
      done
      echo "  }"
      echo "}"
    } > "$layout_file"

    echo ""
    echo "Launching zellij session '${SESSION_NAME}' with ${#TARGETS[@]} pane(s)..."

    unset ZELLIJ ZELLIJ_SESSION_NAME
    zellij -s "$SESSION_NAME" -n "$layout_file"
    rm -f "$layout_file"
    exit 0
  fi

  # --- Fallback: sequential push (no zellij) ----------------------------------
  for image in "${TARGETS[@]}"; do
    echo ""
    echo "--- Pushing ${image} ---"
    PUSH_FLAGS=()
    $DRY_RUN && PUSH_FLAGS+=(--dry-run)
    $FORCE_UP && PUSH_FLAGS+=(-up)
    $VERBOSE && PUSH_FLAGS+=(--verbose)
    $RELEASE && PUSH_FLAGS+=(--release)
    [[ "${AUTO_YES:-}" == "true" ]] && PUSH_FLAGS+=(--yes)
    "$0" "$image" "${PUSH_FLAGS[@]+"${PUSH_FLAGS[@]}"}"
  done
  exit 0
fi

# --- Determine target repo ---------------------------------------------------
ORIGINAL_DIR="$(pwd)"
IN_PROJECT_DIR=false

if [[ -n "$TARGET" ]]; then
  IMAGE="$TARGET"
elif detect_docker_repo "$ORIGINAL_DIR"; then
  IMAGE="$DETECTED_REPO"
  IN_PROJECT_DIR=true
else
  # Not in a project folder — smart prompt based on recency
  IMAGE=""
  ELAPSED=$(seconds_since_last_build)
  load_build_state

  if [[ -n "${LAST_BUILD_IMAGE:-}" ]] && (( ELAPSED < 60 )); then
    # < 60 seconds since last build — quick prompt
    echo "Recent build detected: ${LAST_BUILD_IMAGE} (${ELAPSED}s ago)"
    if _confirm "Push ${LAST_BUILD_IMAGE}?"; then
      IMAGE="$LAST_BUILD_IMAGE"
    fi

  elif [[ -n "${LAST_BUILD_IMAGE:-}" ]] && (( ELAPSED <= 300 )); then
    # 1-5 minutes — still offer last build
    echo "Last build: ${LAST_BUILD_IMAGE} ($(( ELAPSED / 60 ))m $(( ELAPSED % 60 ))s ago)"
    if _confirm "Push ${LAST_BUILD_IMAGE}?"; then
      IMAGE="$LAST_BUILD_IMAGE"
    fi
  fi

  # > 5 minutes or user declined — show unpushed builds toggle list
  if [[ -z "$IMAGE" ]]; then
    UNPUSHED="$(get_unpushed_builds)"

    if [[ -n "$UNPUSHED" ]]; then
      echo ""
      echo "Unpushed builds:"
      UNPUSHED_ENTRIES=()
      UNPUSHED_SELECTED=()
      idx=0

      while IFS= read -r entry; do
        entry_time="${entry%%|*}"
        entry_rest="${entry#*|}"
        entry_image="${entry_rest%%|*}"
        entry_age=$(( $(date +%s) - entry_time ))
        entry_min=$(( entry_age / 60 ))
        UNPUSHED_ENTRIES+=("$entry")
        UNPUSHED_SELECTED+=(true)
        echo "  [x] $((idx+1))) ${entry_image} (${entry_min}m ago)"
        idx=$((idx + 1))
      done <<< "$UNPUSHED"

      echo ""
      echo "Toggle: number(s), range (1-5), 'a'=all, 'n'=none, enter/'go'=confirm, 'q'=quit"

      while true; do
        _toggle_input UNPUSHED_SELECTED "${#UNPUSHED_ENTRIES[@]}" && rc=0 || rc=$?
        [[ $rc -eq 2 ]] && { echo "Aborted."; exit 0; }
        [[ $rc -eq 1 ]] && break

        # Redisplay
        for i in "${!UNPUSHED_ENTRIES[@]}"; do
          e="${UNPUSHED_ENTRIES[$i]}"
          e_rest="${e#*|}"
          e_img="${e_rest%%|*}"
          mark="[ ]"
          [[ "${UNPUSHED_SELECTED[$i]}" == "true" ]] && mark="[x]"
          echo "  ${mark} $((i+1))) ${e_img}"
        done
      done

      # Push selected entries
      for i in "${!UNPUSHED_ENTRIES[@]}"; do
        if [[ "${UNPUSHED_SELECTED[$i]}" == "true" ]]; then
          e="${UNPUSHED_ENTRIES[$i]}"
          e_rest="${e#*|}"
          e_img="${e_rest%%|*}"
          echo ""
          echo "--- Pushing ${e_img} ---"
          PUSH_FLAGS=()
          $DRY_RUN && PUSH_FLAGS+=(--dry-run)
          $FORCE_UP && PUSH_FLAGS+=(-up)
          $VERBOSE && PUSH_FLAGS+=(--verbose)
          "$0" "$e_img" "${PUSH_FLAGS[@]+"${PUSH_FLAGS[@]}"}"
        fi
      done
      exit 0

    else
      # No unpushed builds — prompt for target
      echo "No recent builds found."
      echo ""
      echo "Available targets:"
      for i in "${!DOCKER_REPOS[@]}"; do
        echo "  $((i+1))) ${DOCKER_REPOS[$i]}"
      done
      echo ""
      read -r -p "Which repo to push? [1-${#DOCKER_REPOS[@]}] " choice
      if [[ ! "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#DOCKER_REPOS[@]} )); then
        echo "Invalid selection."
        exit 1
      fi
      IMAGE="${DOCKER_REPOS[$((choice-1))]}"
    fi
  fi
fi

# --- Navigate to repo directory -----------------------------------------------
REPO_DIR="$(get_repo_dir "$IMAGE")"
if [[ ! -d "$REPO_DIR" ]]; then
  echo "❌  Repo directory not found: $REPO_DIR"
  exit 1
fi
cd "$REPO_DIR"

# --- Source shared version resolver -------------------------------------------
if [[ -f "$SCRIPT_DIR/../k8-lib/docker-vsn.sh" ]]; then
  source "$SCRIPT_DIR/../k8-lib/docker-vsn.sh"
else
  echo "❌  Cannot find k8-lib/docker-vsn.sh"
  exit 1
fi

GIT_SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")

# --- Resolve version ----------------------------------------------------------
VSN_INPUT="${VSN_POSITIONAL:-${BUILD_VSN:-}}"

if ! resolve_vsn "$REGISTRY" "$IMAGE" "$VSN_INPUT"; then
  if [[ -n "${RECENT_TAGS:-}" ]]; then
    echo ""
    echo "   Most recent tags: ${RECENT_TAGS}"
    echo "   Specify version explicitly:  docker-push ${IMAGE} v1.0.edge-dev"
  fi
  exit 1
fi

echo "📋  ${IMAGE} v${VSN_MAJOR}.${VSN_MINOR}.edge (${BUILD_ENV})"
echo "   Infisical key: ${VERSION_KEY} / ${VERSION_TYPE_KEY}"
echo "   Placeholder:   ${PLACEHOLDER_TAG}"
$DRY_RUN && echo "   Mode:          DRY RUN (no push, no version update)"
$FORCE_UP && [[ "$BUILD_ENV" != "prod" ]] && echo "   Flags:         -up (force patch increment)"

# --- Validate placeholder tag -------------------------------------------------
if [[ "${PLACEHOLDER_TAG}" != *".edge"* && "${PLACEHOLDER_TAG}" != *".X"* ]]; then
  echo "❌  Placeholder tag missing .edge/.X — cannot resolve patch version"
  echo "   Tag: ${PLACEHOLDER_TAG}"
  exit 1
fi
if ! docker image inspect "${PLACEHOLDER_TAG}" &>/dev/null; then
  echo "❌  Image not found: ${PLACEHOLDER_TAG}"
  echo "   Run docker-build ${IMAGE} first (with BUILD_ENV=${BUILD_ENV})"
  exit 1
fi

# --- Confirm non-stage/prod push ----------------------------------------------
if [[ "$BUILD_ENV" != "stage" && "$BUILD_ENV" != "prod" ]] && ! $DRY_RUN; then
  echo "⚠️  Pushing with BUILD_ENV=${BUILD_ENV} (not stage/prod)"
  _confirm "   Continue?" || { echo "Aborted."; exit 0; }
fi

# --- Infisical config ---------------------------------------------------------
INFISICAL_HOST="${INFISICAL_HOST:-${K8_INFISICAL_HOST:-}}"
PROJECT_ID="${INFISICAL_PROJECT_ID:-${K8_INFISICAL_PROJECT_ID:-}}"
ENV_SLUG="${INFISICAL_ENV:-prod}"
VERSIONS_PATH="/docker-versions"

EKS_OPERATOR_CLIENT_ID="${EKS_OPERATOR_CLIENT_ID:-}"
EKS_OPERATOR_CLIENT_SECRET="${EKS_OPERATOR_CLIENT_SECRET:-}"
if [[ -z "$EKS_OPERATOR_CLIENT_ID" || -z "$EKS_OPERATOR_CLIENT_SECRET" ]]; then
  echo "❌  EKS_OPERATOR_CLIENT_ID and EKS_OPERATOR_CLIENT_SECRET must be set"
  echo "   source .envrc or export them manually"
  exit 1
fi

# --- Auth ---------------------------------------------------------------------
echo "🔑  Authenticating with Infisical..."

AUTH_CURL_CMD="curl -s -X POST ${INFISICAL_HOST}/api/v1/auth/universal-auth/login -H 'Content-Type: application/json' -d '{\"clientId\":\"${EKS_OPERATOR_CLIENT_ID}\",\"clientSecret\":\"${EKS_OPERATOR_CLIENT_SECRET}\"}'"

LOGIN_RESPONSE=$(curl -s -X POST "${INFISICAL_HOST}/api/v1/auth/universal-auth/login" \
  -H "Content-Type: application/json" \
  -d "{\"clientId\":\"${EKS_OPERATOR_CLIENT_ID}\",\"clientSecret\":\"${EKS_OPERATOR_CLIENT_SECRET}\"}" 2>&1) || true

API_TOKEN=$(echo "$LOGIN_RESPONSE" | grep -o '"accessToken":"[^"]*"' | cut -d'"' -f4 || true)
if [[ -z "$API_TOKEN" ]]; then
  echo "❌  Authentication failed"
  echo ""
  echo "   Replay manually:"
  echo "   $AUTH_CURL_CMD"
  echo ""
  echo "   Response:"
  echo "   $LOGIN_RESPONSE"
  exit 1
fi
echo "  ✅  Authenticated"

# --- Infisical helpers --------------------------------------------------------
_fetch_secret() {
  local key="$1"
  local response
  response=$(curl -s \
    "${INFISICAL_HOST}/api/v4/secrets/${key}" \
    -H "Authorization: Bearer ${API_TOKEN}" \
    -G --data-urlencode "projectId=${PROJECT_ID}" \
       --data-urlencode "environment=${ENV_SLUG}" \
       --data-urlencode "secretPath=${VERSIONS_PATH}" \
       --data-urlencode "type=shared" \
    || echo "")
  echo "$response" | grep -o '"secretValue":"[^"]*"' | cut -d'"' -f4 || echo ""
}

_update_secret() {
  local key="$1" value="$2"
  local http_code

  http_code=$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST "${INFISICAL_HOST}/api/v4/secrets/${key}" \
    -H "Authorization: Bearer ${API_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "{\"projectId\":\"${PROJECT_ID}\",\"environment\":\"${ENV_SLUG}\",\"secretPath\":\"${VERSIONS_PATH}\",\"secretValue\":\"${value}\",\"type\":\"shared\"}")

  if [[ "$http_code" != "200" && "$http_code" != "201" ]]; then
    http_code=$(curl -s -o /dev/null -w "%{http_code}" \
      -X PATCH "${INFISICAL_HOST}/api/v4/secrets/${key}" \
      -H "Authorization: Bearer ${API_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "{\"projectId\":\"${PROJECT_ID}\",\"environment\":\"${ENV_SLUG}\",\"secretPath\":\"${VERSIONS_PATH}\",\"secretValue\":\"${value}\",\"type\":\"shared\"}")
  fi
  echo "$http_code"
}

# --- Infisical updates to apply -----------------------------------------------
UPDATES=()

# --- Resolve version based on environment -------------------------------------
if [[ "$BUILD_ENV" == "prod" ]]; then
  # PROD: increment VERSION_KEY (patch) → v{MAJOR}.{MINOR}.{NEXT_PATCH}
  echo "📦  Fetching patch version (${VERSION_KEY})..."
  CURRENT_PATCH=$(_fetch_secret "$VERSION_KEY")

  if [[ -z "$CURRENT_PATCH" || "$CURRENT_PATCH" == "null" ]]; then
    NEXT_PATCH=0
    echo ""
    echo "⚠️  v${VSN_MAJOR}.${VSN_MINOR} not yet released for ${IMAGE}"
    echo "   This will be the first push (v${VSN_MAJOR}.${VSN_MINOR}.0)."
    if ! $DRY_RUN; then
      # Safety: always prompt for CHANGELOG even with --yes
      _saved_auto_yes="$AUTO_YES"; AUTO_YES=false
      _confirm "   Have you updated CHANGELOG.md?" || { echo "Aborted."; exit 0; }
      AUTO_YES="$_saved_auto_yes"
    fi
  else
    NEXT_PATCH=$((CURRENT_PATCH + 1))
  fi

  VERSION_TAG="v${VSN_MAJOR}.${VSN_MINOR}.${NEXT_PATCH}"
  UPDATES+=("${VERSION_KEY}=${NEXT_PATCH}")

  echo "  Current: ${CURRENT_PATCH:-<unset>}"
  echo "  Next:    ${VERSION_TAG}"
  echo ""

  if ! $DRY_RUN; then
    if ! check_stale_local_tags "$REGISTRY" "$IMAGE" "$VSN_MAJOR" "$VSN_MINOR" "${CURRENT_PATCH:-0}" "$ENV_SUFFIX"; then
      exit 1
    fi
  fi

else
  # NON-PROD: patch + sub-version → v{MAJOR}.{MINOR}.{PATCH}-{env}.{SUB}
  echo "📦  Fetching patch version (${VERSION_KEY})..."
  CURRENT_PATCH=$(_fetch_secret "$VERSION_KEY")

  if $FORCE_UP; then
    if [[ -z "$CURRENT_PATCH" || "$CURRENT_PATCH" == "null" ]]; then
      PATCH_FOR_TAG=0
    else
      PATCH_FOR_TAG=$((CURRENT_PATCH + 1))
    fi
    UPDATES+=("${VERSION_KEY}=${PATCH_FOR_TAG}")
    echo "  Patch: ${CURRENT_PATCH:-<unset>} → ${PATCH_FOR_TAG} (-up)"
  else
    if [[ -z "$CURRENT_PATCH" || "$CURRENT_PATCH" == "null" ]]; then
      PATCH_FOR_TAG=0
      echo "  ⚠️  No patch version found — using 0"
    else
      PATCH_FOR_TAG="$CURRENT_PATCH"
    fi
    echo "  Patch: ${PATCH_FOR_TAG} (read-only)"
  fi

  echo "📦  Fetching sub-version (${VERSION_TYPE_KEY})..."
  CURRENT_SUB=$(_fetch_secret "$VERSION_TYPE_KEY")

  if [[ -z "$CURRENT_SUB" || "$CURRENT_SUB" == "null" ]]; then
    NEXT_SUB=0
    echo ""
    echo "⚠️  v${VSN_MAJOR}.${VSN_MINOR}.${PATCH_FOR_TAG}${ENV_SUFFIX} not yet released for ${IMAGE}"
    echo "   This will be the first ${BUILD_ENV} push for this version track."
    if ! $DRY_RUN; then
      _confirm "   Continue?" || { echo "Aborted."; exit 0; }
    fi
  else
    NEXT_SUB=$((CURRENT_SUB + 1))
  fi

  UPDATES+=("${VERSION_TYPE_KEY}=${NEXT_SUB}")
  VERSION_TAG="v${VSN_MAJOR}.${VSN_MINOR}.${PATCH_FOR_TAG}${ENV_SUFFIX}.${NEXT_SUB}"

  echo "  Sub:     ${CURRENT_SUB:-<unset>} → ${NEXT_SUB}"
  echo "  Next:    ${VERSION_TAG}"
  echo ""
fi

# --- Collect all tags to push ------------------------------------------------
EDGE_TAG="v${VSN_MAJOR}.${VSN_MINOR}.edge${ENV_SUFFIX}"

PUSH_TAGS=("${VERSION_TAG}" "${EDGE_TAG}")
PUSH_LABELS=("version" "edge pin")
if [[ -n "$GIT_SHA" && "$GIT_SHA" != "unknown" ]]; then
  PUSH_TAGS+=("${GIT_SHA}")
  PUSH_LABELS+=("commit")
fi

# --- Check remote registry for existing tags ---------------------------------
# Returns "exists|<config_digest>" , "new|", or "unknown|"
# config_digest is the image config sha — directly comparable to docker inspect .Id
_check_ecr_tag() {
  local repo="$1" tag="$2"
  if ! command -v aws &>/dev/null; then
    echo "unknown|"; return
  fi

  # Quick existence check
  local output
  output=$(aws ecr describe-images \
    --repository-name "$repo" \
    --image-ids imageTag="$tag" \
    --region "${K8_AWS_REGION:-us-east-1}" 2>&1) || true

  if echo "$output" | grep -q "ImageNotFoundException"; then
    echo "new|"; return
  elif ! echo "$output" | grep -q "imageDigest"; then
    echo "unknown|"; return
  fi

  # Fetch the manifest to extract the config digest (comparable to local image ID)
  local manifest
  manifest=$(aws ecr batch-get-image \
    --repository-name "$repo" \
    --image-ids imageTag="$tag" \
    --accepted-media-types "application/vnd.docker.distribution.manifest.v2+json" \
    --query 'images[0].imageManifest' \
    --output text \
    --region "${K8_AWS_REGION:-us-east-1}" 2>/dev/null) || true

  local config_digest=""
  if [[ -n "$manifest" && "$manifest" != "None" ]]; then
    config_digest=$(echo "$manifest" | grep -o '"config"[^}]*' | grep -o '"digest"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | grep -o 'sha256:[a-f0-9]*')
  fi

  echo "exists|${config_digest}"
}

# Get the full local image config digest (sha256:...)
_local_image_id() {
  local img="$1"
  docker inspect --format='{{.Id}}' "$img" 2>/dev/null || echo ""
}

# --- Check if image unchanged from edge — skip version increment if so -------
LOCAL_DIGEST=$(_local_image_id "${PLACEHOLDER_TAG}")
LOCAL_SHORT=$(echo "$LOCAL_DIGEST" | sed 's/sha256://' | cut -c1-12)
EDGE_MATCHES_LOCAL=false

if ! $FORCE_UP && [[ -n "$LOCAL_DIGEST" ]]; then
  _edge_result=$(_check_ecr_tag "$IMAGE" "$EDGE_TAG")
  _edge_status="${_edge_result%%|*}"
  _edge_digest="${_edge_result#*|}"
  if [[ "$_edge_status" == "exists" && -n "$_edge_digest" && "$_edge_digest" == "$LOCAL_DIGEST" ]]; then
    EDGE_MATCHES_LOCAL=true
    # Revert to current version (don't increment)
    if [[ "$BUILD_ENV" == "prod" ]]; then
      if [[ -n "$CURRENT_PATCH" && "$CURRENT_PATCH" != "null" ]]; then
        VERSION_TAG="v${VSN_MAJOR}.${VSN_MINOR}.${CURRENT_PATCH}"
      fi
    else
      if [[ -n "$CURRENT_SUB" && "$CURRENT_SUB" != "null" ]]; then
        VERSION_TAG="v${VSN_MAJOR}.${VSN_MINOR}.${PATCH_FOR_TAG}${ENV_SUFFIX}.${CURRENT_SUB}"
      fi
    fi
    PUSH_TAGS[0]="$VERSION_TAG"
    UPDATES=()
    echo "  ⚡ Image unchanged from edge — version not incremented (${VERSION_TAG})"
  fi
fi

echo ""
echo "  Push Plan: ${IMAGE}"
echo "  ────────────────────────────────────────────────"

if [[ -n "$LOCAL_SHORT" ]]; then
  echo "    local:  ${LOCAL_SHORT}"
fi

EXISTING_TAGS=()
NEW_TAGS=()
UNKNOWN_TAGS=()
ALL_SAME=true
ALL_MATCH_LOCAL=true
FIRST_REMOTE_DIGEST=""

for i in "${!PUSH_TAGS[@]}"; do
  tag="${PUSH_TAGS[$i]}"
  label="${PUSH_LABELS[$i]}"
  result=$(_check_ecr_tag "$IMAGE" "$tag")
  status="${result%%|*}"
  remote_digest="${result#*|}"
  case "$status" in
    exists)
      short_digest=""
      match_marker=""
      if [[ -n "$remote_digest" ]]; then
        short_digest=$(echo "$remote_digest" | sed 's/sha256://' | cut -c1-12)
        # Track whether all remote digests match each other
        if [[ -z "$FIRST_REMOTE_DIGEST" ]]; then
          FIRST_REMOTE_DIGEST="$remote_digest"
        elif [[ "$remote_digest" != "$FIRST_REMOTE_DIGEST" ]]; then
          ALL_SAME=false
        fi
        # Compare remote config digest to local image ID
        if [[ -n "$LOCAL_DIGEST" && "$remote_digest" == "$LOCAL_DIGEST" ]]; then
          match_marker="="
        else
          match_marker="≠"
          ALL_MATCH_LOCAL=false
        fi
      else
        ALL_MATCH_LOCAL=false
      fi
      printf '    %-40s  exists  [%s]  %s %s\n' ":${tag}" "$label" "${short_digest:+${short_digest}}" "$match_marker"
      EXISTING_TAGS+=("$tag")
      ;;
    new)
      printf '    %-40s  new     [%s]\n' ":${tag}" "$label"
      NEW_TAGS+=("$tag")
      ALL_SAME=false
      ALL_MATCH_LOCAL=false
      ;;
    *)
      printf '    %-40s  ?       [%s]\n' ":${tag}" "$label"
      UNKNOWN_TAGS+=("$tag")
      ALL_MATCH_LOCAL=false
      ;;
  esac
done

echo "  ────────────────────────────────────────────────"
echo "    ${#NEW_TAGS[@]} new, ${#EXISTING_TAGS[@]} overwrite, ${#UNKNOWN_TAGS[@]} unchecked"

# Check if the local image is identical to what's already in ECR
if (( ${#EXISTING_TAGS[@]} > 0 )) && $ALL_MATCH_LOCAL && (( ${#NEW_TAGS[@]} == 0 )); then
  echo ""
  echo "  ⚡ Remote image is identical to local — nothing to push."
  if ! $DRY_RUN; then
    _confirm "   Push anyway?" || { echo "  Skipped (no changes)."; exit 0; }
  else
    echo "  DRY RUN — would skip (no changes)."
    exit 0
  fi
  echo ""
elif (( ${#EXISTING_TAGS[@]} > 1 )) && $ALL_SAME && (( ${#NEW_TAGS[@]} == 0 )); then
  echo "    ⚡ all remote tags point to the same image"
fi
echo ""

# --- Dry-run exit -------------------------------------------------------------
if $DRY_RUN; then
  echo "=============================================="
  echo "  DRY RUN — would push:"
  for i in "${!PUSH_TAGS[@]}"; do
    echo "     ${REGISTRY}/${IMAGE}:${PUSH_TAGS[$i]}  [${PUSH_LABELS[$i]}]"
  done
  echo ""
  for upd in "${UPDATES[@]}"; do
    echo "   Would update ${VERSIONS_PATH}/${upd%%=*} → ${upd#*=}"
  done
  echo "=============================================="
  exit 0
fi

# --- Confirm overwrites -------------------------------------------------------
if (( ${#EXISTING_TAGS[@]} > 0 )); then
  echo "  ${#EXISTING_TAGS[@]} tag(s) already exist in ECR and will be overwritten:"
  for etag in "${EXISTING_TAGS[@]}"; do
    echo "     ${REGISTRY}/${IMAGE}:${etag}"
  done
  _confirm "   Overwrite existing tags?" || { echo "Aborted."; exit 0; }
  echo ""
fi

# --- Retag --------------------------------------------------------------------
echo "🏷️   Retagging → ${VERSION_TAG}..."
docker tag "${PLACEHOLDER_TAG}" "${REGISTRY}/${IMAGE}:${VERSION_TAG}"

# --- Update Infisical ---------------------------------------------------------
for upd in "${UPDATES[@]}"; do
  upd_key="${upd%%=*}"
  upd_val="${upd#*=}"
  echo "📝  Updating ${upd_key} in Infisical → ${upd_val}..."
  HTTP_CODE=$(_update_secret "$upd_key" "$upd_val")
  if [[ "$HTTP_CODE" == "200" || "$HTTP_CODE" == "201" ]]; then
    echo "  ✅  ${upd_key} → ${upd_val}"
  else
    echo "  ❌  Failed to update ${upd_key} (HTTP ${HTTP_CODE})"
    echo "     Cleaning up local tag to prevent version drift..."
    cleanup_version_tag "$REGISTRY" "$IMAGE" "$VERSION_TAG"
    echo "     Fix Infisical access or manually set ${VERSIONS_PATH}/${upd_key} = ${upd_val}, then retry."
    exit 1
  fi
done

# --- Push helper (logs to file, prints dots — or streams in verbose mode) -----
_push_with_dots() {
  local full_tag="$1" logfile="$2"
  if $VERBOSE; then
    echo "" >&2
    docker push "$full_tag" 2>&1
    local rc=$?
    echo "[verbose] push exited $rc" >> "$logfile"
    return $rc
  fi
  docker push "$full_tag" >> "$logfile" 2>&1 &
  local push_pid=$!
  local elapsed=0
  while kill -0 "$push_pid" 2>/dev/null; do
    sleep 5
    elapsed=$((elapsed + 5))
    if (( elapsed % 60 == 0 )); then
      printf "." >&2
    fi
  done
  wait "$push_pid"
  return $?
}

# --- Push ---------------------------------------------------------------------
PUSH_LOG="${INFRA_ROOT}/.tmp/docker-push-${IMAGE}-$(date +%Y%m%d-%H%M%S).log"
mkdir -p "${INFRA_ROOT}/.tmp"
echo "🚀  Pushing ${#PUSH_TAGS[@]} tag(s)...  (log: ${PUSH_LOG})"
PUSHED_OK=()
PUSHED_FAIL=()

for i in "${!PUSH_TAGS[@]}"; do
  tag="${PUSH_TAGS[$i]}"
  label="${PUSH_LABELS[$i]}"
  printf "   🕐 :%-40s [%s] " "${tag}" "${label}" >&2
  if [[ "$label" == "commit" ]]; then
    # SHA tag is best-effort — don't fail the push
    if _push_with_dots "${REGISTRY}/${IMAGE}:${tag}" "$PUSH_LOG"; then
      PUSHED_OK+=("$tag")
      echo " ok" >&2
    else
      PUSHED_FAIL+=("$tag")
      echo " skip" >&2
    fi
  else
    if _push_with_dots "${REGISTRY}/${IMAGE}:${tag}" "$PUSH_LOG"; then
      PUSHED_OK+=("$tag")
      echo " ok" >&2
    else
      echo " FAILED (see ${PUSH_LOG})" >&2
      echo "❌  Push failed for :${tag} — check log: ${PUSH_LOG}"
      exit 1
    fi
  fi
done

echo ""
echo "=============================================="
echo "  Pushed ${#PUSHED_OK[@]}/${#PUSH_TAGS[@]} tags → ${IMAGE}"
for ptag in "${PUSHED_OK[@]}"; do
  echo "     ✅  :${ptag}"
done
if [[ ${#PUSHED_FAIL[@]} -gt 0 ]]; then
  for ptag in "${PUSHED_FAIL[@]}"; do
    echo "     ⚠️   :${ptag}  (skipped)"
  done
fi
echo "=============================================="

# --- Update helm values tag (--release) ----------------------------------------
if $RELEASE; then
  _helm_dir="${INFRA_ROOT}/helm/${IMAGE}"

  if [[ ! -d "$_helm_dir" ]]; then
    echo "⚠️  No helm chart at ${_helm_dir} — skipping tag update"
  else
    _values_file=""
    case "$BUILD_ENV" in
      prod|production) _values_file="${_helm_dir}/values.yaml" ;;
      *)               _values_file="${_helm_dir}/values-${BUILD_ENV}.yaml" ;;
    esac

    if [[ ! -f "$_values_file" ]]; then
      echo "⚠️  Values file not found: ${_values_file} — skipping tag update"
    else
      if grep -q "repository:.*/${IMAGE}" "$_values_file" 2>/dev/null; then
        awk -v tag="$VERSION_TAG" -v img="$IMAGE" '
          /repository:/ && index($0, img) { found=1 }
          found && /tag:/ {
            match($0, /^[[:space:]]*/);
            indent = substr($0, RSTART, RLENGTH);
            $0 = indent "tag: \"" tag "\"";
            found=0
          }
          { print }
        ' "$_values_file" > "${_values_file}.tmp" && mv "${_values_file}.tmp" "$_values_file"
      else
        awk -v tag="$VERSION_TAG" '
          /image:/ && !done { in_image=1 }
          in_image && /tag:/ {
            match($0, /^[[:space:]]*/);
            indent = substr($0, RSTART, RLENGTH);
            $0 = indent "tag: \"" tag "\"";
            in_image=0; done=1
          }
          in_image && /^[^ ]/ { in_image=0 }
          { print }
        ' "$_values_file" > "${_values_file}.tmp" && mv "${_values_file}.tmp" "$_values_file"
      fi
      echo "📋  Updated ${_values_file##*/}: image.tag → ${VERSION_TAG}"
    fi
  fi
fi

# --- Record push state --------------------------------------------------------
record_push_state "$IMAGE" "$GIT_SHA" "$VERSION_TAG"

# --- Check for other unpushed builds ------------------------------------------
cd "$ORIGINAL_DIR"

REMAINING="$(get_unpushed_builds)"
if [[ -n "$REMAINING" ]]; then
  # Filter out the build we just pushed
  OTHER_BUILDS=""
  while IFS= read -r line; do
    line_rest="${line#*|}"
    line_img="${line_rest%%|*}"
    [[ "$line_img" == "$IMAGE" ]] && continue
    OTHER_BUILDS="${OTHER_BUILDS:+${OTHER_BUILDS}
}${line}"
  done <<< "$REMAINING"

  if [[ -n "$OTHER_BUILDS" ]] && [[ "$AUTO_YES" != "true" ]]; then
    # Dedup by image name — keep the most recent (last) entry per image
    # (bash 3 compatible — no associative arrays)
    DEDUPED_BUILDS=""
    _dedup_imgs=""
    while IFS= read -r line; do
      line_rest="${line#*|}"
      line_img="${line_rest%%|*}"
      # Skip if we already have a newer entry for this image
      case ",$_dedup_imgs," in
        *,"$line_img",*) continue ;;
      esac
      _dedup_imgs="${_dedup_imgs:+${_dedup_imgs},}${line_img}"
      DEDUPED_BUILDS="${DEDUPED_BUILDS:+${DEDUPED_BUILDS}
}${line}"
    done <<< "$(echo "$OTHER_BUILDS" | sort -t'|' -k1,1nr)"

    echo ""
    echo "Other unpushed builds:"
    while IFS= read -r line; do
      line_time="${line%%|*}"
      line_rest="${line#*|}"
      line_img="${line_rest%%|*}"
      line_rest2="${line_rest#*|}"
      line_rest3="${line_rest2#*|}"
      line_vsn="${line_rest3}"
      line_age=$(( $(date +%s) - line_time ))
      line_min=$(( line_age / 60 ))
      echo "  - ${line_img}  ${line_vsn}  (${line_min}m ago)"
    done <<< "$DEDUPED_BUILDS"

    if [[ "$AUTO_YES" == "true" ]]; then
      CONFIRM_RESULT="n"
    else
      _confirm_yiN "Push remaining builds?"
    fi
    if [[ "$CONFIRM_RESULT" == "y" ]]; then
      while IFS= read -r line; do
        line_rest="${line#*|}"
        line_img="${line_rest%%|*}"
        echo ""
        echo "--- Pushing ${line_img} ---"
        "$0" "$line_img"
      done <<< "$DEDUPED_BUILDS"

    elif [[ "$CONFIRM_RESULT" == "i" ]]; then
      # Interactive toggle selection
      INTER_ENTRIES=()
      INTER_SELECTED=()
      idx=0
      while IFS= read -r entry; do
        entry_time="${entry%%|*}"
        entry_rest="${entry#*|}"
        entry_img="${entry_rest%%|*}"
        entry_rest2="${entry_rest#*|}"
        entry_rest3="${entry_rest2#*|}"
        entry_vsn="${entry_rest3}"
        entry_age=$(( $(date +%s) - entry_time ))
        entry_min=$(( entry_age / 60 ))
        INTER_ENTRIES+=("$entry")
        INTER_SELECTED+=(true)
        echo "  [x] $((idx+1))) ${entry_img}  ${entry_vsn}  (${entry_min}m ago)"
        idx=$((idx + 1))
      done <<< "$DEDUPED_BUILDS"

      echo ""
      echo "Toggle: number(s), range (1-5), 'a'=all, 'n'=none, enter/'go'=confirm, 'q'=quit"

      while true; do
        _toggle_input INTER_SELECTED "${#INTER_ENTRIES[@]}" && rc=0 || rc=$?
        [[ $rc -eq 2 ]] && { echo "Aborted."; exit 0; }
        [[ $rc -eq 1 ]] && break

        # Redisplay
        for i in "${!INTER_ENTRIES[@]}"; do
          e="${INTER_ENTRIES[$i]}"
          e_rest="${e#*|}"
          e_img="${e_rest%%|*}"
          e_rest2="${e_rest#*|}"
          e_rest3="${e_rest2#*|}"
          e_vsn="${e_rest3}"
          mark="[ ]"
          [[ "${INTER_SELECTED[$i]}" == "true" ]] && mark="[x]"
          echo "  ${mark} $((i+1))) ${e_img}  ${e_vsn}"
        done
      done

      # Push selected entries
      for i in "${!INTER_ENTRIES[@]}"; do
        if [[ "${INTER_SELECTED[$i]}" == "true" ]]; then
          e="${INTER_ENTRIES[$i]}"
          e_rest="${e#*|}"
          e_img="${e_rest%%|*}"
          echo ""
          echo "--- Pushing ${e_img} ---"
          PUSH_FLAGS=()
          $DRY_RUN && PUSH_FLAGS+=(--dry-run)
          $FORCE_UP && PUSH_FLAGS+=(-up)
          $VERBOSE && PUSH_FLAGS+=(--verbose)
          "$0" "$e_img" "${PUSH_FLAGS[@]+"${PUSH_FLAGS[@]}"}"
        fi
      done
    fi
  fi
fi
